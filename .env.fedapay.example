# Configuration Fedapay
# Pour obtenir ces clés, créez un compte sur https://fedapay.com
# En mode sandbox (test), utilisez les clés préfixées par pk_sandbox_ et sk_sandbox_
# En mode live (production), utilisez les clés préfixées par pk_live_ et sk_live_

FEDAPAY_PUBLIC_KEY=pk_sandbox_your_public_key_here
FEDAPAY_SECRET_KEY=sk_sandbox_your_secret_key_here
FEDAPAY_ENVIRONMENT=sandbox
FEDAPAY_WEBHOOK_SECRET=your_webhook_secret_here

# Notes:
# - Remplacez les valeurs par vos vraies clés API Fedapay
# - Le webhook secret est disponible dans Dashboard Fedapay > Paramètres > Webhooks
# - Configurez l'URL du webhook: https://votre-domaine.com/webhook/fedapay
# - En production, changez FEDAPAY_ENVIRONMENT=live et utilisez vos clés de production
