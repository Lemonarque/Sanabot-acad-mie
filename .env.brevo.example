APP_ENV=production
APP_DEBUG=false

# URL publique de l'application
APP_URL=https://votre-domaine.com

# Mail - Brevo SMTP
MAIL_MAILER=smtp
MAIL_SCHEME=tls
MAIL_HOST=smtp-relay.brevo.com
MAIL_PORT=587
MAIL_USERNAME=votre_login_smtp_brevo
MAIL_PASSWORD=votre_cle_smtp_brevo

# Expéditeur (doit être validé dans Brevo)
MAIL_FROM_ADDRESS=no-reply@votre-domaine.com
MAIL_FROM_NAME="Sanabot Academie"